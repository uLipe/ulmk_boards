+static int tas_client_op_run(struct aurix_ocds *ocds)
+{
+	struct tas_client_con_queue *q = &client_state.con_queues[ocds->con_id];
+	uint32_t pl0_buffer[q->max_pkt_size / 4];
+	uint32_t off = 0;
+	int err;
+
+	/*
+	 * Server caps RW ops per PL0 (Lite Kit: 32).  Local queue is larger so
+	 * flash can batch a full 256 B burst (37 ops) into one aurix_ocds_run();
+	 * we split into pl0_max_rw-sized packets here.
+	 */
+	while (off < q->reqs_count) {
+		uint32_t n = q->pl0_max_rw ? MIN(q->pl0_max_rw, q->reqs_count - off)
+					   : (q->reqs_count - off);
+		size_t pl0_size = 0;
+
+		err = tas_client_encode_pl0(ocds, off, n, pl0_buffer, &pl0_size);
+		if (err) {
+			q->reqs_count = 0;
+			return err;
+		}
+
+		err = tas_client_send_pl0(client_state.sock, ocds->con_id,
+					  pl0_buffer, pl0_size, n);
+		if (err) {
+			q->reqs_count = 0;
+			return err;
+		}
+
+		err = tas_client_parse_pl0_rsp(ocds, pl0_buffer, off, n);
+		if (err) {
+			q->reqs_count = 0;
+			return err;
+		}
+
+		off += n;
+	}
+
+	q->reqs_count = 0;
+	return ERROR_OK;
 }
 
