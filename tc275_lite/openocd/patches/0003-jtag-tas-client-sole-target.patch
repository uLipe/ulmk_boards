+static int tas_client_encode_pl0(struct aurix_ocds *ocds, uint32_t req_off,
+				 uint32_t req_n, uint32_t *pl0_buffer,
+				 size_t *pl0_size_out)
+{
+	uint32_t base_address = 0xFFFFFFFF;
+	uint32_t i;
+	size_t pl0_size = 0;
+	uint32_t max_bytes = client_state.con_queues[ocds->con_id].max_pkt_size;
+
+	for (i = 0; i < req_n; i++) {
+		struct tas_client_pl0_req *req =
+			&client_state.con_queues[ocds->con_id].reqs[req_off + i];
+		size_t need;
+
+		if ((req->addr & 0xFFFF0000) != base_address)
+			need = sizeof(tas_pl0rq_base_addr32_st);
+		else
+			need = 0;
+
+		if ((req->cmd & 0x1) == 1 || req->cmd == TAS_PL0_CMD_RDBLK) {
+			if (req->cmd < TAS_PL0_CMD_RDBLK)
+				need += sizeof(tas_pl0rq_rd_st);
+			else
+				need += sizeof(tas_pl0rq_rdblk_st);
+		} else if (req->cmd == TAS_PL0_CMD_WR64) {
+			need += sizeof(tas_pl0rq_wr64_st);
+		} else if (req->cmd < TAS_PL0_CMD_WRBLK) {
+			need += sizeof(tas_pl0rq_wr_st);
+		} else {
+			need += sizeof(tas_pl0rq_wrblk_st) + req->count * 4;
+		}
+
+		if (pl0_size + need > max_bytes)
+			return ERROR_FAIL;
+
+		if ((req->addr & 0xFFFF0000) != base_address) {
+			tas_pl0rq_base_addr32_st base_addr = {
+				.wl = 0,
+				.cmd = TAS_PL0_CMD_BASE_ADDR32,
+				.ba31to16 = req->addr >> 16,
+			};
+			memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+			       &base_addr, sizeof(base_addr));
+			pl0_size += sizeof(base_addr);
+			base_address = req->addr & 0xFFFF0000;
+		}
+
+		if ((req->cmd & 0x1) == 1 || req->cmd == TAS_PL0_CMD_RDBLK) {
+			if (req->cmd < TAS_PL0_CMD_RDBLK) {
+				tas_pl0rq_rd_st read_addr = {
+					.wl = 0,
+					.cmd = req->cmd,
+					.a15to0 = req->addr & 0xFFFF,
+				};
+				memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+				       &read_addr, sizeof(read_addr));
+				pl0_size += sizeof(read_addr);
+			} else {
+				tas_pl0rq_rdblk_st read_addr = {
+					.wl = 1,
+					.cmd = req->cmd,
+					.wlrd = req->count,
+					.a15to0 = req->addr & 0xFFFF,
+				};
+				memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+				       &read_addr, sizeof(read_addr));
+				pl0_size += sizeof(read_addr);
+			}
+		} else if (req->cmd == TAS_PL0_CMD_WR64) {
+			tas_pl0rq_wr64_st write_addr = {
+				.wl = 2,
+				.cmd = req->cmd,
+				.a15to0 = req->addr & 0xFFFF,
+			};
+			memcpy(write_addr.data, &req->data,
+			       sizeof(write_addr.data));
+			memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+			       &write_addr, sizeof(write_addr));
+			pl0_size += sizeof(write_addr);
+		} else if (req->cmd < TAS_PL0_CMD_WRBLK) {
+			tas_pl0rq_wr_st write_addr = {
+				.wl = 1,
+				.cmd = req->cmd,
+				.a15to0 = req->addr & 0xFFFF,
+				.data = (uint32_t)req->data,
+			};
+			memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+			       &write_addr, sizeof(write_addr));
+			pl0_size += sizeof(write_addr);
+		} else {
+			tas_pl0rq_wrblk_st write_addr = {
+				.wl = req->count,
+				.cmd = req->cmd,
+				.a15to0 = req->addr & 0xFFFF,
+			};
+			memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+			       &write_addr, sizeof(write_addr));
+			pl0_size += sizeof(write_addr);
+			memcpy(pl0_buffer + pl0_size / sizeof(uint32_t),
+			       req->buffer, req->count * sizeof(uint32_t));
+			pl0_size += req->count * 4;
+		}
+	}
+
+	*pl0_size_out = pl0_size;
+	return ERROR_OK;
+}
 
